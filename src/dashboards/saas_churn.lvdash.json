{
  "datasets": [
    {
      "name": "kpis",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT SUM(active_mrr) AS total_active_mrr, SUM(account_count)-SUM(churned_account_count) AS active_accounts, SUM(churned_account_count)/SUM(account_count) AS overall_churn_rate, SUM(active_mrr)/(SUM(account_count)-SUM(churned_account_count)) AS avg_mrr_per_active FROM ai_dev_kit_testing.default.gold_mrr_by_plan_industry"
      ]
    },
    {
      "name": "mrr_by_segment",
      "displayName": "MRR by Industry & Plan",
      "queryLines": [
        "SELECT industry, plan_type, active_mrr FROM ai_dev_kit_testing.default.gold_mrr_by_plan_industry"
      ]
    },
    {
      "name": "mrr_growth",
      "displayName": "Cumulative MRR",
      "queryLines": [
        "WITH monthly AS (SELECT DATE_TRUNC('MONTH', contract_start_date) AS month, SUM(CASE WHEN status='active' THEN monthly_recurring_revenue ELSE 0 END) AS active_mrr_month FROM ai_dev_kit_testing.default.silver_account_health GROUP BY DATE_TRUNC('MONTH', contract_start_date)) SELECT month, SUM(active_mrr_month) OVER (ORDER BY month ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cumulative_active_mrr FROM monthly ORDER BY month"
      ]
    },
    {
      "name": "lifecycle",
      "displayName": "Lifecycle",
      "queryLines": [
        "SELECT plan_type, CASE status WHEN 'active' THEN '1 Active' WHEN 'trial' THEN '2 Trial' WHEN 'churned' THEN '3 Churned' END AS lifecycle_stage, COUNT(*) AS account_count FROM ai_dev_kit_testing.default.silver_account_health GROUP BY plan_type, status"
      ]
    },
    {
      "name": "top_accounts",
      "displayName": "Top accounts",
      "queryLines": [
        "SELECT company_name, usage_event_count_90d AS total_events FROM ai_dev_kit_testing.default.silver_account_health ORDER BY usage_event_count_90d DESC LIMIT 20"
      ]
    },
    {
      "name": "engagement",
      "displayName": "Engagement",
      "queryLines": [
        "SELECT company_name, plan_type, usage_event_count_90d AS total_events, total_session_minutes_90d AS total_session_minutes, total_pages_viewed_90d AS pages_viewed FROM ai_dev_kit_testing.default.silver_account_health WHERE usage_event_count_90d > 0"
      ]
    },
    {
      "name": "risk_kpis",
      "displayName": "Risk KPIs",
      "queryLines": [
        "SELECT SUM(CASE WHEN risk_band='High' THEN 1 ELSE 0 END) AS high_risk_accounts, SUM(CASE WHEN risk_band='High' THEN monthly_recurring_revenue ELSE 0 END) AS mrr_at_risk, SUM(CASE WHEN risk_band='Medium' THEN 1 ELSE 0 END) AS medium_risk_accounts FROM ai_dev_kit_testing.default.account_churn_scores"
      ]
    },
    {
      "name": "best_model",
      "displayName": "Best model",
      "queryLines": [
        "SELECT best_model, best_auc FROM ai_dev_kit_testing.default.churn_training_status"
      ]
    },
    {
      "name": "risk_band",
      "displayName": "Risk band",
      "queryLines": [
        "SELECT risk_band, COUNT(*) AS accounts FROM ai_dev_kit_testing.default.account_churn_scores GROUP BY risk_band"
      ]
    },
    {
      "name": "model_leaderboard",
      "displayName": "Model leaderboard",
      "queryLines": [
        "SELECT model, auc FROM ai_dev_kit_testing.default.churn_model_metrics"
      ]
    },
    {
      "name": "feature_importance",
      "displayName": "Feature importance",
      "queryLines": [
        "SELECT feature, importance FROM ai_dev_kit_testing.default.churn_feature_importance ORDER BY importance DESC"
      ]
    },
    {
      "name": "top_at_risk",
      "displayName": "Top at-risk",
      "queryLines": [
        "SELECT account_id, plan_type, monthly_recurring_revenue, total_events_90d, churn_risk, risk_band FROM ai_dev_kit_testing.default.account_churn_scores ORDER BY churn_risk DESC LIMIT 20"
      ]
    }
  ],
